# Porta do servidor backend
PORT=4000

# String de conexao do MongoDB (Atlas ou local)
# Exemplo Atlas: mongodb+srv://usuario:senha@cluster.xxxxx.mongodb.net
# Exemplo local: mongodb://127.0.0.1:27017
MONGODB_URI=mongodb://127.0.0.1:27017

# Nome do banco de dados
MONGODB_DB_NAME=opella_abrafarma

# Origem(ns) permitida(s) para CORS (separe por virgula se houver mais de uma)
# Use * para liberar geral (nao recomendado em producao)
CORS_ORIGIN=http://localhost:5173

# URL publica do frontend (usada para montar o link dentro do QR Code)
# Ex: https://seu-dominio.com
FRONTEND_URL=http://localhost:5173

# Chave simples para proteger a tela de leitura/baixa do brinde (tablet)
# Quem for dar baixa precisa enviar esse token no header "x-staff-token"
STAFF_TOKEN=troque-esta-chave
